{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-render-app.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://your-backend-render-app.onrender.com/socket.io/:path*"
    },
    {
      "source": "/((?!api|socket.io).*)",
      "destination": "/index.html"
    }
  ]
}
